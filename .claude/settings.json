{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-check.sh",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "bun run lint 実行中..."
          }
        ]
      }
    ]
  }
}
